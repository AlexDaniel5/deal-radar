# Copy to .env and fill in. .env is gitignored and never committed.
# The Anthropic API key is read from the environment by the AI evaluator,
# not from the YAML config.
ANTHROPIC_API_KEY=

# Only needed if you add a Telegram notifier (referenced in config as ${TELEGRAM_BOT_TOKEN}).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
